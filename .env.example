# ─────────────────────────────────────────────────────────────
#  LIGHTNING TIPPING WIDGET — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to ".env.local" for local dev, and set the same
# variables in the Vercel dashboard for production.

# ── LNbits backend (the real Lightning node) ──────────────────
# Any LNbits instance works. The app is network-agnostic: point it
# at a TESTNET/SIGNET LNbits to demo with no real money, or a
# MAINNET LNbits for true on-chain tips of a few sats.
#
# How to get these:
#   1. Open your LNbits instance (e.g. https://demo.lnbits.com).
#   2. Create a wallet.
#   3. Click "API docs / API info" in the wallet to reveal the keys.
#
# Only the INVOICE/READ key is required (the app is receive-only).
LNBITS_URL=https://demo.lnbits.com
LNBITS_INVOICE_KEY=your_invoice_read_key_here

# ── Creator profile (the single creator this deployment serves) ─
CREATOR_NAME=Alice
CREATOR_HANDLE=alice@getalby.com
CREATOR_MESSAGE=Support my work with a Lightning tip ⚡

# Comma-separated preset tip amounts (in sats) shown as quick buttons.
CREATOR_PRESET_AMOUNTS=100,500,1000

# Network label shown on the widget badge: mainnet | testnet | signet
# (purely cosmetic — the real network is determined by your LNbits node)
NETWORK_LABEL=testnet

# Public base URL of THIS deployment (used to generate the embed snippet).
# Locally this is http://localhost:3000; on Vercel set your prod URL.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
